public class Tree {
    public static ArrayList<Integer> getNeighbours(int nodeIndex, ArrayList<ArrayList<Integer>> adjList){
        ArrayList<Integer> children = new ArrayList<>();
        ArrayList<Integer> srcArray = adjList.get(nodeIndex);
        for(int i = 0; i < srcArray.size(); i++){
            if(i == 0)
                continue;
            children.add(srcArray.get(i));
        }
        return children;
    }
    public static int getNodeValue(int node, ArrayList<ArrayList<Integer>> adjList){
        return adjList.get(node).get(0);
    }
    public static boolean isLeaf(int node, ArrayList<ArrayList<Integer>> adjList){
        ArrayList<Integer> neighbours = getNeighbours(node, adjList);
        return neighbours.isEmpty();
    }
    public static int sumOfLeaves(int root, ArrayList<ArrayList<Integer>> adjList){
        int leafValueCount = 0;
        if(root == -1)
            return 0;
        if(isLeaf(root, adjList))
            return getNodeValue(root, adjList);
        boolean[] marked = new boolean[adjList.size()];
        Queue<Integer> storage = new LinkedList<>();
        storage.add(root);
        if(!marked[root]){
            marked[root] = true;
            while(!storage.isEmpty()){
                int var = storage.poll();
                for(int w : getNeighbours(var, adjList)){
                    if(marked[w] == false){
                        marked[w] = true;
                        storage.add(w);
                        if(isLeaf(w, adjList))
                            leafValueCount += getNodeValue(w, adjList);
                    }
                }
            }
        }
        return leafValueCount;
    }
    public static int heightOfTree_BFS(int root, ArrayList<ArrayList<Integer>> adjList){
        if(root == -1)
            return 0;
        int height = 0;
        boolean[] marked = new boolean[adjList.size()];
        Queue<Integer> storage = new LinkedList<>();
        storage.add(root);
        if(marked[root] == false){
            marked[root] = true;
            height++;
            while(!storage.isEmpty()){
                int lvlSize = storage.size();
                height++;
                for(int i = 0; i < lvlSize; i++){
                    int var = storage.poll();
                    for(int w : getNeighbours(var, adjList)){
                        if(marked[w] == false){
                            marked[w] = true;
                            storage.add(w);
                        }
                    }
                    
                }
            }
        }
        return height;
    }
    
    public static int heightOfTree_DFS(int root, ArrayList<ArrayList<Integer>> adjList){
        int height = 0;
        if(isLeaf(root, adjList))
            return 0;
        ArrayList<Integer> neighbours = getNeighbours(root, adjList);
        for(int w : neighbours){
            int childHeight = heightOfTree_DFS(w, adjList);
            height = Math.max(height, childHeight);
        }
        return height + 1;
    }
}
//rooting a tree
class treeNode{
    int id;
    treeNode parent;
    ArrayList<treeNode> children;
    public treeNode(int id, treeNode parent){
        this.id = id;
        this.parent = parent;
        this.children = new ArrayList<>();
    }
    public treeNode rootTree(ArrayList<ArrayList<Integer>> tree, int id){
        treeNode root = new treeNode(id, null);
        return buildTree(tree, root, null);
    }
    public treeNode buildTree(ArrayList<ArrayList<Integer>> tree, treeNode curr, treeNode parent){
        for(int neighID : tree.get(curr.id)){
            if(parent != null && neighID == parent.id)
                continue;
            treeNode child = new treeNode(neighID, curr);
            curr.children.add(child);
            buildTree(tree, child, curr);
        }
        return curr;
    }
}
